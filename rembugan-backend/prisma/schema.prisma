// KONFIGURASI PRISMA & DATABASE
generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. ENTITAS UTAMA (USER & PROFIL)
model User {
  id            String    @id @default(uuid())
  
  // Kredensial (Multi-Auth)
  nim           String    @unique // Wajib, identitas utama mahasiswa
  password      String    // Wajib, di-hash saat registrasi
  email         String?   @unique
  email_verified Boolean  @default(false)
  
  // Data Profil Dasar
  full_name     String
  handle        String?   @unique // @username untuk profil
  major         String
  bio           String?
  photo_url     String?   
  cover_url     String?   
  social_links  Json?
  is_onboarded  Boolean   @default(false)
  
  // Relasi ke Data Lain
  skills        UserSkill[]
  experiences   Experience[]
  showcases     Showcase[]
  
  // Relasi ke Proyek
  ownedProjects Project[]            @relation("ProjectOwner")
  memberships   ProjectMember[]
  applications  ProjectApplication[]
  
  // Relasi ke Workspace
  tasksAssigned Task[]               @relation("TaskAssignee")
  sentMessages  Message[]            @relation("SentMessages")
  receivedMsgs  Message[]            @relation("ReceivedMessages")

  // Relasi ke Interaksi Sosial & Notifikasi
  likes         ShowcaseLike[]
  comments      ShowcaseComment[]
  sentConnections Connection[]       @relation("SentConnections")
  receivedConnections Connection[]   @relation("ReceivedConnections")
  uploadedFiles   ProjectFile[]
  notifications Notification[]

  // Relasi ke OTP & Saved Items
  otp_codes     OtpCode[]
  savedItems    SavedItem[]

  // Timestamps
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
}

// 1b. ENTITAS OTP (Verifikasi Email)
model OtpCode {
  id         Int      @id @default(autoincrement())
  user_id    String
  email      String
  code_hash  String   // SHA256 hash dari OTP
  expires_at DateTime
  attempts   Int      @default(0)
  used       Boolean  @default(false)
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([email])
}

// 2. ENTITAS SKILL & PENGALAMAN (PORTFOLIO)
model Skill {
  id    Int         @id @default(autoincrement())
  name  String      @unique
  users UserSkill[]
}

model UserSkill {
  user_id  String
  skill_id Int
  
  user     User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  skill    Skill @relation(fields: [skill_id], references: [id], onDelete: Cascade)

  @@id([user_id, skill_id]) // Composite Primary Key
}

model Experience {
  id          Int       @id @default(autoincrement())
  user_id     String
  title       String    // Misal: "Frontend Developer"
  company     String    // Misal: "Lab Informatika"
  description String?
  start_date  DateTime
  end_date    DateTime? // Jika Null berarti "Masih Berlangsung"
  
  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

// 3. ENTITAS PROYEK & MATCHING
model Project {
  id              Int                  @id @default(autoincrement())
  owner_id        String
  title           String
  description     String
  required_skills String[]             // Array of String untuk memudahkan pencarian AI
  status          String               @default("open") // Status: 'open', 'ongoing', 'completed'
  
  // Field tambahan untuk UI Flutter
  category        String?              // Kategori proyek (Tech, Design, Business, dll)
  faculty         String?              // Fakultas terkait proyek
  deadline        DateTime?            // Batas waktu pendaftaran
  total_slots     Int?                 // Total slot anggota yang dibutuhkan
  
  owner           User                 @relation("ProjectOwner", fields: [owner_id], references: [id])
  members         ProjectMember[]
  applications    ProjectApplication[]
  tasks           Task[]
  messages        Message[]
  showcases       Showcase[]
  invites         ProjectInvite[]
  savedBy         SavedItem[]
  files           ProjectFile[]

  created_at      DateTime             @default(now())

  @@index([status])
  @@index([owner_id])
  @@index([category])
  @@index([faculty])
  @@index([deadline])
}

model ProjectApplication {
  id           Int      @id @default(autoincrement())
  project_id   Int
  applicant_id String
  status       String   @default("pending") // Status: 'pending', 'accepted', 'rejected'
  
  project      Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  applicant    User     @relation(fields: [applicant_id], references: [id], onDelete: Cascade)
  applied_at   DateTime @default(now())

  @@index([project_id, status])
  @@index([applicant_id])
}

model ProjectMember {
  id         Int      @id @default(autoincrement())
  project_id Int
  user_id    String
  role       String   @default("Anggota") // Role: 'Ketua', 'Anggota', 'Pembimbing'
  
  project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([user_id])
}

// 3b. UNDANGAN PROYEK (QR INVITE)
model ProjectInvite {
  id          String    @id @default(uuid())
  project_id  Int
  token       String    @unique
  created_by  String
  expires_at  DateTime
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())

  project     Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

// 3c. ITEM YANG DISIMPAN (BOOKMARK)
model SavedItem {
  id         Int      @id @default(autoincrement())
  user_id    String
  project_id Int?
  showcase_id String?
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  project    Project? @relation(fields: [project_id], references: [id], onDelete: Cascade)
  showcase   Showcase? @relation(fields: [showcase_id], references: [id], onDelete: Cascade)

  @@unique([user_id, project_id])
  @@unique([user_id, showcase_id])
}

// 4. ENTITAS WORKSPACE (KANBAN & CHAT)
model Task {
  id          Int      @id @default(autoincrement())
  project_id  Int
  assignee_id String?  // Siapa yang mengerjakan tugas ini
  title       String
  status      String   @default("todo") // Kolom Kanban: 'todo', 'doing', 'done'
  deadline    DateTime? // Batas waktu tugas
  
  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  assignee    User?    @relation("TaskAssignee", fields: [assignee_id], references: [id], onDelete: SetNull)
  created_at  DateTime @default(now())

  @@index([project_id, status])
  @@index([assignee_id])
}

model Message {
  id          Int      @id @default(autoincrement())
  content     String
  sender_id   String
  
  // Fleksibilitas Chat: DM atau Group
  receiver_id String?  // Diisi jika ini adalah DM pribadi (Direct Message)
  project_id  Int?     // Diisi jika ini adalah Group Chat di dalam Workspace
  
  sender      User     @relation("SentMessages", fields: [sender_id], references: [id], onDelete: Cascade)
  receiver    User?    @relation("ReceivedMessages", fields: [receiver_id], references: [id], onDelete: Cascade)
  project     Project? @relation(fields: [project_id], references: [id], onDelete: Cascade)

  created_at  DateTime @default(now())

  @@index([sender_id])
  @@index([receiver_id])
  @@index([project_id])
}

// 5. ENTITAS SHOWCASE (PORTOFOLIO/DOKUMENTASI)
model Showcase {
  id                String   @id @default(uuid())
  author_id         String
  content           String
  media_urls        String[]
  tags              String[]
  linked_project_id Int?     // Relasi ke Project (jika showcase ini hasil dari proyek Rembugan)
  created_at        DateTime @default(now())

  // Relasi
  author            User     @relation(fields: [author_id], references: [id], onDelete: Cascade)
  project           Project? @relation(fields: [linked_project_id], references: [id], onDelete: SetNull)
  likes             ShowcaseLike[]
  comments          ShowcaseComment[]
  savedBy           SavedItem[]

  @@index([author_id])
}

// 6. INTERAKSI SHOWCASE (LIKE & KOMENTAR)
model ShowcaseLike {
  id          Int      @id @default(autoincrement())
  showcase_id String
  user_id     String
  created_at  DateTime @default(now())

  showcase    Showcase @relation(fields: [showcase_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([showcase_id, user_id])
}

model ShowcaseComment {
  id          Int               @id @default(autoincrement())
  showcase_id String
  user_id     String
  content     String
  parent_id   Int?              // Untuk balas-balasan
  created_at  DateTime          @default(now())

  showcase    Showcase          @relation(fields: [showcase_id], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  parent      ShowcaseComment?  @relation("CommentReplies", fields: [parent_id], references: [id], onDelete: Cascade)
  replies     ShowcaseComment[] @relation("CommentReplies")
}

// 6b. WORKSPACE FILES
model ProjectFile {
  id         Int      @id @default(autoincrement())
  project_id Int
  user_id    String
  name       String
  url        String
  size       Int?     // size in bytes
  mime_type  String?
  created_at DateTime @default(now())

  project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  uploader   User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

// 7. KONEKSI & NOTIFIKASI
model Connection {
  id          Int      @id @default(autoincrement())
  sender_id   String
  receiver_id String
  status      String   @default("pending") // 'pending', 'accepted', 'rejected'
  created_at  DateTime @default(now())

  sender      User     @relation("SentConnections", fields: [sender_id], references: [id], onDelete: Cascade)
  receiver    User     @relation("ReceivedConnections", fields: [receiver_id], references: [id], onDelete: Cascade)

  @@unique([sender_id, receiver_id])
}

model Notification {
  id          Int      @id @default(autoincrement())
  user_id     String   // Penerima notif
  type        String   // 'like', 'comment', 'chat', 'group_chat_tag', 'todo_deadline', 'connection_request', 'connection_accepted'
  title       String
  content     String
  is_read     Boolean  @default(false)
  link        String?  // Link menuju ke detail (misal: /showcase/xxx)
  created_at  DateTime @default(now())

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_read])
  @@index([type])
}